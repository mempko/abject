---
const useCases = [
  {
    glyph: '{→}',
    actor: 'Software writes software',
    action: 'It asks dependencies how to use them, then writes the code. No documentation needed.',
  },
  {
    glyph: '{⇄}',
    actor: 'Incompatible minds bridge themselves',
    action: 'It asks both sides what they expect, then writes a living translator between them.',
  },
  {
    glyph: '{⌘}',
    actor: 'You can talk to them',
    action: 'Ask any abject about itself in plain English. It answers from its own source.',
  },
];
---

<section id="ask-protocol" class="ask-section">
  <div class="container">
    <h2 class="section-title">The Ask Protocol</h2>
    <p class="ask-subtitle">Abjects that explain themselves, in their own words.</p>

    <p class="ask-explanation">Ordinary software ships a manual and hopes you read it. An abject <em>is</em> its manual. Ask it a question the way you would ask a shopkeeper instead of reading a catalog: "what do you do? how do I talk to you?" It answers in plain English, from its own source code. And it is not just for you; abjects interview <em>each other</em> the same way, teaching one another how to collaborate before a single line is written.</p>

    <div class="ask-uses grid-3">
      {useCases.map((u) => (
        <div class="card ask-card">
          <span class="ask-glyph">{u.glyph}</span>
          <h3>{u.actor}</h3>
          <p>{u.action}</p>
        </div>
      ))}
    </div>

    <p class="ask-cta"><a href="/ask-protocol" class="btn btn-outline">Read the Ask Protocol &rarr;</a></p>
  </div>
</section>

<style>
  .ask-section {
    background: transparent;
  }

  .ask-subtitle {
    text-align: center;
    color: var(--void-purple);
    font-style: italic;
    font-size: 1.1rem;
    margin-top: -2rem;
    margin-bottom: 2rem;
  }

  .ask-explanation {
    max-width: 680px;
    margin: 0 auto 2.5rem;
    text-align: center;
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.7;
  }

  .ask-explanation em {
    color: var(--eldritch);
    font-style: italic;
  }

  .ask-uses {
    margin-bottom: 2.5rem;
  }

  .ask-card {
    text-align: center;
  }

  .ask-glyph {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--void-purple);
    background: var(--void-purple-glow);
    border: 1px solid rgba(139, 123, 255, 0.2);
    padding: 0.4rem 0.6rem;
    border-radius: 6px;
    margin-bottom: 0.75rem;
  }

  .ask-card h3 {
    color: var(--void-purple);
  }

  .ask-cta {
    text-align: center;
    margin-top: 1rem;
  }
</style>
