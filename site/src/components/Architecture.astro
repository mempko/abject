---
---

<section id="architecture" class="arch-section">
  <div class="container">
    <h2 class="section-title">The Architecture of the Living System</h2>

    <div class="tiers">
      <div class="tier tier-surface">
        <div class="tier-label">I</div>
        <h3>The Surface</h3>
        <p class="tier-tagline">A window into the abyss.</p>
        <p>Thin browser client, Canvas compositor, input forwarding. Nothing runs here; it only renders what the depths send up.</p>
      </div>

      <div class="tier-connector">
        <span class="connector-line"></span>
        <span class="connector-glyph">↕</span>
        <span class="connector-label">WS :7719</span>
        <span class="connector-line"></span>
      </div>

      <div class="tier tier-depths">
        <div class="tier-label">II</div>
        <h3>The Depths</h3>
        <p class="tier-tagline">Where the Abjects dwell.</p>
        <p>MessageBus, Registry, Factory, Negotiator, Supervisor, LLM, ProxyGenerator, HealthMonitor. Every system service is an Abject: same manifests, same message protocol, same contracts.</p>
      </div>

      <div class="tier-connector">
        <span class="connector-line"></span>
        <span class="connector-glyph">↕</span>
        <span class="connector-label">WorkerBridge</span>
        <span class="connector-line"></span>
      </div>

      <div class="tier tier-containment">
        <div class="tier-label">III</div>
        <h3>The Containment</h3>
        <p class="tier-tagline">Cages for things that cannot be trusted.</p>
        <p>Worker pool with WASM sandboxes. Capability-gated imports. No ambient authority. Untrusted Abjects run here; they can see only what you allow them to see.</p>
      </div>
    </div>

    <div class="arch-cake">
      <h3>The Layer Cake</h3>
      <p class="arch-cake-intro">Inside the Depths, abjects organize into three tiers. Workspaces at the top are isolated bubbles, each with its own zoo of abjects. They rest on a shared layer of system abjects, which all talk to each other through a single MessageBus underneath.</p>

      <svg class="cake-svg" viewBox="0 0 720 540" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Abject's layered architecture: workspaces on top, system abjects in the middle, and a single MessageBus at the base">
        <defs>
          <filter id="cake-glow">
            <feGaussianBlur stdDeviation="2.5" result="blur"/>
            <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
          </filter>
          <marker id="cake-flow" viewBox="0 0 10 10" refX="10" refY="5" markerWidth="6" markerHeight="6" orient="auto">
            <path d="M 0 0 L 10 5 L 0 10 z" fill="rgba(57,255,142,0.5)"/>
          </marker>
        </defs>

        <!-- Tier 3 label -->
        <text x="40" y="22" fill="#9a9aae" font-size="11" font-family="monospace" letter-spacing="0.12em">// WORKSPACES (isolated)</text>

        <!-- Workspace A -->
        <rect x="40" y="35" width="310" height="175" rx="10" fill="#0e0e18" stroke="rgba(57,255,142,0.4)" stroke-width="1.5" stroke-dasharray="6 3"/>
        <text x="58" y="58" fill="rgba(57,255,142,0.7)" font-size="11" font-family="monospace" font-weight="600">workspace: default</text>
        <text x="60" y="86" fill="#39ff8e" font-size="13" font-family="monospace">Chat</text>
        <text x="60" y="108" fill="#39ff8e" font-size="13" font-family="monospace">ScrumMaster</text>
        <text x="60" y="130" fill="#39ff8e" font-size="13" font-family="monospace">GoalManager &middot; TupleSpace</text>
        <text x="60" y="152" fill="#39ff8e" font-size="13" font-family="monospace">KnowledgeBase</text>
        <text x="60" y="174" fill="#39ff8e" font-size="13" font-family="monospace">SkillRegistry &middot; Theme</text>
        <text x="60" y="198" fill="rgba(57,255,142,0.55)" font-size="11" font-family="monospace" font-style="italic">+ Goals, Jobs, Web, ...</text>

        <!-- Workspace B -->
        <rect x="370" y="35" width="310" height="175" rx="10" fill="#0e0e18" stroke="rgba(57,255,142,0.4)" stroke-width="1.5" stroke-dasharray="6 3"/>
        <text x="388" y="58" fill="rgba(57,255,142,0.7)" font-size="11" font-family="monospace" font-weight="600">workspace: research</text>
        <text x="390" y="86" fill="#39ff8e" font-size="13" font-family="monospace">Chat</text>
        <text x="390" y="108" fill="#39ff8e" font-size="13" font-family="monospace">ScrumMaster</text>
        <text x="390" y="130" fill="#39ff8e" font-size="13" font-family="monospace">GoalManager &middot; TupleSpace</text>
        <text x="390" y="152" fill="#39ff8e" font-size="13" font-family="monospace">WebBrowserViewer</text>
        <text x="390" y="174" fill="#39ff8e" font-size="13" font-family="monospace">KnowledgeBase</text>
        <text x="390" y="198" fill="rgba(57,255,142,0.55)" font-size="11" font-family="monospace" font-style="italic">each workspace, its own zoo</text>

        <!-- Down arrows: Workspaces → System tier -->
        <line x1="120" y1="210" x2="120" y2="245" stroke="rgba(57,255,142,0.4)" stroke-width="1" marker-end="url(#cake-flow)"/>
        <line x1="200" y1="210" x2="200" y2="245" stroke="rgba(57,255,142,0.4)" stroke-width="1" marker-end="url(#cake-flow)"/>
        <line x1="280" y1="210" x2="280" y2="245" stroke="rgba(57,255,142,0.4)" stroke-width="1" marker-end="url(#cake-flow)"/>
        <line x1="430" y1="210" x2="430" y2="245" stroke="rgba(57,255,142,0.4)" stroke-width="1" marker-end="url(#cake-flow)"/>
        <line x1="520" y1="210" x2="520" y2="245" stroke="rgba(57,255,142,0.4)" stroke-width="1" marker-end="url(#cake-flow)"/>
        <line x1="610" y1="210" x2="610" y2="245" stroke="rgba(57,255,142,0.4)" stroke-width="1" marker-end="url(#cake-flow)"/>

        <!-- Tier 2 label -->
        <text x="40" y="242" fill="#9a9aae" font-size="11" font-family="monospace" letter-spacing="0.12em">// SYSTEM ABJECTS (shared)</text>

        <!-- Tier 2: System Abjects band -->
        <rect x="40" y="255" width="640" height="100" rx="10" fill="#0e0e18" stroke="rgba(57,255,142,0.5)" stroke-width="1.5"/>
        <text x="360" y="285" text-anchor="middle" fill="#39ff8e" font-size="14" font-family="monospace">Registry &middot; Factory &middot; LLMObject &middot; ObjectCreator &middot; ProxyGenerator</text>
        <text x="360" y="310" text-anchor="middle" fill="#39ff8e" font-size="14" font-family="monospace">Negotiator &middot; HealthMonitor &middot; WorkspaceManager &middot; Supervisor</text>
        <text x="360" y="335" text-anchor="middle" fill="#39ff8e" font-size="14" font-family="monospace">IdentityObject &middot; PeerRegistry &middot; RemoteRegistry</text>

        <!-- Down arrows: System → MessageBus -->
        <line x1="120" y1="355" x2="120" y2="390" stroke="rgba(57,255,142,0.4)" stroke-width="1" marker-end="url(#cake-flow)"/>
        <line x1="240" y1="355" x2="240" y2="390" stroke="rgba(57,255,142,0.4)" stroke-width="1" marker-end="url(#cake-flow)"/>
        <line x1="360" y1="355" x2="360" y2="390" stroke="rgba(57,255,142,0.4)" stroke-width="1" marker-end="url(#cake-flow)"/>
        <line x1="480" y1="355" x2="480" y2="390" stroke="rgba(57,255,142,0.4)" stroke-width="1" marker-end="url(#cake-flow)"/>
        <line x1="600" y1="355" x2="600" y2="390" stroke="rgba(57,255,142,0.4)" stroke-width="1" marker-end="url(#cake-flow)"/>

        <!-- Tier 1 label -->
        <text x="40" y="387" fill="#9a9aae" font-size="11" font-family="monospace" letter-spacing="0.12em">// MESSAGEBUS (substrate)</text>

        <!-- Tier 1: MessageBus band -->
        <rect x="40" y="400" width="640" height="90" rx="10" fill="#0e0e18" stroke="#39ff8e" stroke-width="2" filter="url(#cake-glow)"/>
        <line x1="60" y1="416" x2="660" y2="416" stroke="rgba(57,255,142,0.3)" stroke-width="0.5"/>
        <line x1="60" y1="474" x2="660" y2="474" stroke="rgba(57,255,142,0.3)" stroke-width="0.5"/>
        <text x="360" y="437" text-anchor="middle" fill="#39ff8e" font-size="18" font-family="monospace" font-weight="700">MessageBus</text>
        <text x="360" y="462" text-anchor="middle" fill="rgba(57,255,142,0.75)" font-size="12" font-family="monospace" font-style="italic">every message between any two abjects flows here</text>

        <!-- Caption -->
        <text x="360" y="520" text-anchor="middle" fill="#9a9aae" font-size="11" font-family="monospace" font-style="italic">workspaces are isolated; everything underneath is shared</text>
      </svg>

      <p class="arch-note">Layers are conceptual, not enforced by privilege. The MessageBus does not know what a "system abject" is. Everything is just an abject sending messages.</p>
    </div>
  </div>
</section>

<style>
  .arch-section {
    background: transparent;
  }

  .tiers {
    max-width: 640px;
    margin: 0 auto 3rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .tier {
    width: 100%;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.75rem 2rem;
    position: relative;
    transition: border-color 0.3s, box-shadow 0.3s;
  }

  .tier:hover {
    border-color: var(--border-accent);
    box-shadow: 0 0 24px var(--eldritch-glow);
  }

  .tier-label {
    position: absolute;
    top: -0.6rem;
    right: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--eldritch);
    background: var(--bg-deep);
    padding: 0 0.5rem;
  }

  .tier h3 {
    color: var(--eldritch);
    margin-bottom: 0.25rem;
  }

  .tier-tagline {
    color: var(--void-purple);
    font-style: italic;
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }

  .tier p:last-child {
    color: var(--text-secondary);
    font-size: 0.95rem;
  }

  .tier-containment {
    border-color: rgba(255, 77, 106, 0.15);
  }

  .tier-containment:hover {
    border-color: rgba(255, 77, 106, 0.3);
    box-shadow: 0 0 24px rgba(255, 77, 106, 0.1);
  }

  .tier-containment .tier-label {
    color: var(--ichor);
  }

  .tier-containment h3 {
    color: var(--ichor);
  }

  .tier-connector {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    padding: 0.25rem 0;
  }

  .connector-line {
    width: 1px;
    height: 12px;
    background: var(--eldritch-glow-strong);
    box-shadow: 0 0 6px var(--eldritch-glow);
  }

  .connector-glyph {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--eldritch-dim);
    line-height: 1;
  }

  .connector-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-dim);
  }

  .arch-cake {
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
  }

  .arch-cake h3 {
    color: var(--text-primary);
    margin-bottom: 0.75rem;
  }

  .arch-cake-intro {
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
    line-height: 1.7;
  }

  .cake-svg {
    width: 100%;
    max-width: 720px;
    display: block;
    margin: 0 auto 1rem;
  }

  .arch-note {
    font-size: 0.9rem;
    color: var(--text-dim);
    font-style: italic;
    margin-top: 1rem;
  }
</style>
