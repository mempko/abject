---
---

<header>
  <nav class="container">
    <a href="/" class="logo">
      <span class="logo-bracket">{</span>abjects<span class="logo-bracket">}</span><span class="logo-tagline">An Abject Horror</span>
    </a>
    <div class="nav-links">
      <a href="#ask-protocol">Ask</a>
      <a href="#features">Features</a>
      <a href="#symbiogenesis">Genesis</a>
      <a href="#spreading">P2P</a>
      <a href="#architecture">Architecture</a>
      <a href="#lineage">Lineage</a>
      <a href="#summon">Summon</a>
      <span class="btn btn-outline btn-sm btn-soon">GitHub - Coming Soon</span>
    </div>
  </nav>
</header>

<style>
  header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(3, 3, 8, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }

  .logo {
    font-family: var(--font-mono);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .logo:hover {
    color: var(--eldritch);
    animation: glitch 4s infinite;
  }

  .logo-bracket {
    color: var(--eldritch);
  }

  .logo-tagline {
    color: var(--text-dim);
    font-size: 0.7rem;
    font-weight: 400;
    margin-left: 0.6rem;
    letter-spacing: 0.04em;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.75rem;
  }

  .nav-links a {
    color: var(--text-secondary);
    font-size: 0.9rem;
    font-weight: 500;
    transition: color 0.2s;
  }

  .nav-links a:hover {
    color: var(--text-primary);
  }

  .btn-sm {
    padding: 0.4rem 1rem;
    font-size: 0.85rem;
  }

  .btn-soon {
    cursor: default;
    opacity: 0.6;
    border-color: var(--text-dim);
    color: var(--text-dim);
  }

  @media (max-width: 600px) {
    .nav-links a:not(.btn) {
      display: none;
    }
  }
</style>
