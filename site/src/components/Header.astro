<style>
  header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(3, 3, 8, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }

  .logo {
    font-family: var(--font-mono);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text-primary);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .logo:hover {
    color: var(--eldritch);
    animation: glitch 4s infinite;
  }

  .logo-bracket {
    color: var(--eldritch);
  }

  .logo-tagline {
    color: var(--text-dim);
    font-size: 0.7rem;
    font-weight: 400;
    margin-left: 0.6rem;
    letter-spacing: 0.04em;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-shrink: 0;
  }

  .nav-links a {
    color: var(--text-secondary);
    font-size: 0.85rem;
    font-weight: 500;
    transition: color 0.2s;
    white-space: nowrap;
  }

  .nav-links a:hover {
    color: var(--text-primary);
  }

  .btn-sm {
    padding: 0.4rem 1rem;
    font-size: 0.85rem;
  }

  .btn-icon {
    width: 34px;
    height: 34px;
    padding: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .btn-sm:hover,
  .btn-icon:hover {
    border-color: var(--eldritch);
    color: var(--eldritch);
  }

  @media (max-width: 600px) {
    .nav-links a:not(.btn) {
      display: none;
    }
  }
</style>
