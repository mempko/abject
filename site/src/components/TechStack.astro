---
const tech = [
  { name: 'TypeScript', desc: 'Runtime & language' },
  { name: 'Vite', desc: 'Build tooling' },
  { name: 'WASM', desc: 'Sandboxed execution' },
  { name: 'WebSocket', desc: 'Client-server transport' },
  { name: 'Canvas', desc: 'X11-style compositor' },
  { name: 'WebRTC', desc: 'Peer-to-peer channels' },
  { name: 'Web Crypto', desc: 'ECDSA, ECDH, AES-256-GCM' },
  { name: 'Playwright', desc: 'Headless browser automation' },
];
---

<section class="tech-section">
  <div class="container">
    <h2 class="section-title">Tech Stack</h2>
    <div class="grid-4">
      {tech.map((t) => (
        <div class="tech-card">
          <h3>{t.name}</h3>
          <p>{t.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .tech-card {
    text-align: center;
    padding: 1.5rem 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    transition: border-color 0.3s, box-shadow 0.3s;
  }

  .tech-card:hover {
    border-color: var(--border-accent);
    box-shadow: 0 0 16px var(--accent-glow);
  }

  .tech-card h3 {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--accent);
    margin-bottom: 0.25rem;
  }

  .tech-card p {
    font-size: 0.85rem;
    color: var(--text-dim);
  }
</style>
