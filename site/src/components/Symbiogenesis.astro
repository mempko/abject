          <text x="195" y="115" text-anchor="middle" fill="#5a5a70" font-size="11" font-family="monospace">Tool</text>
          <rect x="255" y="95" width="85" height="30" rx="5" fill="#12121e" stroke="#1a1a2a" stroke-width="1"/>
