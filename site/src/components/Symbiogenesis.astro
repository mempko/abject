    <!-- Zone C: Left-Right Comparisons -->
    <h3 class="compare-heading">How is Abject different?</h3>

    <div class="comparisons">

      <div class="compare-row">
        <div class="compare-label">Agent Frameworks</div>
        <div class="compare-systems">OpenClaw &middot; LangChain &middot; CrewAI</div>
        <svg class="compare-svg" viewBox="0 0 900 170" xmlns="http://www.w3.org/2000/svg">
