          <line x1="195" y1="135" x2="195" y2="152" stroke="#5a5a70" stroke-width="1" stroke-dasharray="3 3"/>
          <line x1="245" y1="135" x2="295" y2="152" stroke="#5a5a70" stroke-width="1" stroke-dasharray="3 3"/>
          <text x="95" y="167" text-anchor="middle" fill="#5a5a70" font-size="9" font-family="monospace">fn()</text>
          <text x="195" y="167" text-anchor="middle" fill="#5a5a70" font-size="9" font-family="monospace">fn()</text>
          <text x="295" y="167" text-anchor="middle" fill="#5a5a70" font-size="9" font-family="monospace">fn()</text>

          <!-- Divider -->
          <line x1="420" y1="10" x2="420" y2="170" stroke="#1a1a2a" stroke-width="1" stroke-dasharray="4 4"/>

          <!-- Right: Negotiator bridging incompatible objects -->
          <text x="660" y="16" text-anchor="middle" fill="rgba(57,255,142,0.5)" font-size="11" font-family="monospace">living negotiation</text>
          <!-- Object A (incompatible) -->
          <rect x="480" y="30" width="100" height="44" rx="6" fill="#12121e" stroke="rgba(57,255,142,0.3)" stroke-width="1"/>
          <text x="530" y="50" text-anchor="middle" fill="#39ff8e" font-size="11" font-family="monospace">Abject A</text>
          <text x="530" y="65" text-anchor="middle" fill="rgba(57,255,142,0.35)" font-size="9" font-family="monospace">interface X</text>
          <!-- Object B (incompatible) -->
          <rect x="740" y="30" width="100" height="44" rx="6" fill="#12121e" stroke="rgba(57,255,142,0.3)" stroke-width="1"/>
          <text x="790" y="50" text-anchor="middle" fill="#39ff8e" font-size="11" font-family="monospace">Abject B</text>
