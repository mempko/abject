---
const repo = 'mempko/abject';
const baseUrl = `https://github.com/${repo}`;
const latestUrl = `${baseUrl}/releases/latest`;

// Fetch electron-builder manifests at build time to resolve direct download URLs
type ReleaseAsset = { url: string; version: string };
type PlatformInfo = { version: string; files: { url: string }[] };

async function fetchManifest(filename: string): Promise<PlatformInfo | null> {
  try {
    const res = await fetch(`${baseUrl}/releases/latest/download/${filename}`);
    if (!res.ok) return null;
    const text = await res.text();
    const version = text.match(/^version:\s*(.+)$/m)?.[1]?.trim() ?? '';
    const files: { url: string }[] = [];
    for (const m of text.matchAll(/^\s+-\s*url:\s*(.+)$/gm)) {
      files.push({ url: m[1].trim() });
    }
    return { version, files };
  } catch { return null; }
}

const [linux, mac, win] = await Promise.all([
  fetchManifest('latest-linux.yml'),
  fetchManifest('latest-mac.yml'),
  fetchManifest('latest.yml'),
]);

const version = linux?.version || mac?.version || win?.version || '';
const dlBase = version ? `${baseUrl}/releases/download/v${version}` : latestUrl;

const linuxAppImage = linux?.files.find(f => f.url.endsWith('.AppImage'))?.url;
const linuxDeb = linux?.files.find(f => f.url.endsWith('.deb'))?.url;
const winExe = win?.files.find(f => f.url.endsWith('.exe'))?.url;
const macDmg = mac?.files.find(f => f.url.endsWith('.dmg'))?.url;
const macZip = mac?.files.find(f => f.url.endsWith('.zip'))?.url;
---

<section id="downloads">
  <div class="container">
    <h2 class="section-title">Incarnate the Organism</h2>
    <p class="dl-subtitle">
      Download Abject as a standalone desktop app. No setup required.
      {version && <span class="dl-version">v{version}</span>}
    </p>
    <div class="dl-grid">

      <!-- Linux -->
      <div class="dl-card">
        <svg class="dl-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/>
          <path d="M12 8v4l2.5 2.5"/>
          <path d="M8 3.5C5.5 5 3.5 8 3.5 12c0 4.5 3.5 8.5 8.5 8.5s8.5-4 8.5-8.5c0-4-2-7-4.5-8.5"/>
          <circle cx="12" cy="12" r="2"/>
        </svg>
        <span class="dl-platform">Linux</span>
        <div class="dl-buttons">
          <a href={linuxAppImage ? `${dlBase}/${linuxAppImage}` : latestUrl} class="dl-btn" target="_blank" rel="noopener">
            AppImage
          </a>
          <a href={linuxDeb ? `${dlBase}/${linuxDeb}` : latestUrl} class="dl-alt" target="_blank" rel="noopener">
            .deb
          </a>
        </div>
      </div>

      <!-- Windows -->
      <div class="dl-card">
        <svg class="dl-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="3" y="3" width="18" height="18" rx="2"/>
          <path d="M3 9h18"/>
          <path d="M9 3v6"/>
          <path d="M3 9l4 4-4 4"/>
          <path d="M21 9l-4 4 4 4"/>
        </svg>
        <span class="dl-platform">Windows</span>
        <div class="dl-buttons">
          <a href={winExe ? `${dlBase}/${winExe}` : latestUrl} class="dl-btn" target="_blank" rel="noopener">
            Installer (.exe)
          </a>
        </div>
      </div>

      <!-- macOS -->
      <div class="dl-card">
        <svg class="dl-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M12 2a10 10 0 100 20 10 10 0 000-20z"/>
          <path d="M12 2c3 3 4.5 7 4.5 10S15 19 12 22"/>
          <path d="M12 2c-3 3-4.5 7-4.5 10S9 19 12 22"/>
          <path d="M2 12h20"/>
        </svg>
        <span class="dl-platform">macOS</span>
        <div class="dl-buttons">
          <a href={macDmg ? `${dlBase}/${macDmg}` : latestUrl} class="dl-btn" target="_blank" rel="noopener">
            .dmg
          </a>
          <a href={macZip ? `${dlBase}/${macZip}` : latestUrl} class="dl-alt" target="_blank" rel="noopener">
            .zip
          </a>
        </div>
      </div>

    </div>
    <p class="dl-invite">
      Try it. Break it. Build something horrible with it.
    </p>
    <p class="dl-note">
      All downloads from the
      <a href={latestUrl} target="_blank" rel="noopener">latest release</a>
      on GitHub.
    </p>
  </div>
</section>

<style>
  #downloads {
    padding: var(--section-gap) 0;
  }

  .dl-subtitle {
    text-align: center;
    color: var(--text-secondary);
    font-size: 1.05rem;
    margin-bottom: 2.5rem;
  }

  .dl-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    max-width: 720px;
    margin: 0 auto;
  }

  .dl-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding: 2rem 1.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    text-decoration: none;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }

  .dl-card:hover {
    border-color: var(--border-accent);
    box-shadow: 0 0 24px var(--eldritch-glow);
    transform: translateY(-2px);
  }

  .dl-icon {
    width: 36px;
    height: 36px;
    color: var(--eldritch);
  }

  .dl-platform {
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .dl-version {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--eldritch-dim);
    margin-left: 0.5rem;
  }

  .dl-buttons {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
  }

  .dl-btn {
    display: inline-block;
    width: 100%;
    text-align: center;
    padding: 0.5rem 1rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--bg-primary);
    background: var(--eldritch);
    border-radius: 6px;
    text-decoration: none;
    transition: background 0.2s, box-shadow 0.2s;
  }

  .dl-btn:hover {
    background: var(--eldritch-bright, #5cffaa);
    box-shadow: 0 0 16px var(--eldritch-glow);
  }

  .dl-alt {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-dim);
    text-decoration: none;
    transition: color 0.2s;
  }

  .dl-alt:hover {
    color: var(--eldritch);
    text-decoration: underline;
  }

  .dl-invite {
    text-align: center;
    margin-top: 2rem;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--text-secondary);
    font-style: italic;
  }

  .dl-note {
    text-align: center;
    margin-top: 1.5rem;
    font-size: 0.85rem;
    color: var(--text-dim);
  }

  .dl-note a {
    color: var(--eldritch-dim);
    text-decoration: none;
  }

  .dl-note a:hover {
    color: var(--eldritch);
    text-decoration: underline;
  }

  @media (max-width: 600px) {
    .dl-grid {
      grid-template-columns: 1fr;
      max-width: 300px;
    }
  }
</style>
