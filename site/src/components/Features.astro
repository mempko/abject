---
const features = [
  {
    icon: '{>}',
    abjects: 'ObjectCreator · Chat',
    title: 'Speak it into existence.',
    hook: '"A todo list that syncs my calendar." Type those words. A window appears.',
    desc: 'Chat decomposes your sentence. The LLM writes a manifest. ObjectCreator spawns the abject. The result is a real running object with its own window, its own mailbox, and source code you can open and read.',
  },
  {
    icon: '{@}',
    abjects: 'IdentityObject · PeerRegistry',
    title: 'Your address is a public key.',
    hook: 'No accounts. No signup. No cloud asking for your email.',
    desc: "Every peer's true name is the SHA-256 hash of its ECDSA P-256 key. Connect over encrypted WebRTC with ECDH key exchange and AES-256-GCM. The signaling server only helps two peers find each other; it never sees a byte of the conversation.",
  },
  {
    icon: '{=}',
    abjects: 'ScrumMaster · GoalManager · TupleSpace',
    title: 'Post a goal. Watch the swarm converge.',
    hook: 'No dispatcher. No queue. No central state holder.',
    desc: 'The goal lives in a TupleSpace synced across peers via CRDT. Abjects answer "what can you do?" through the Ask Protocol; the ScrumMaster picks the best fit each round. Work distributes itself across machines without ever talking to a server.',
  },
  {
    icon: '{!}',
    abjects: 'Negotiator · ProxyGenerator · HealthMonitor',
    title: 'Break it. It tries to grow back.',
    hook: 'Error rate crosses 10%. The LLM drafts a replacement from the crash data.',
    desc: 'When a proxy starts failing, Abject collects the recent errors and asks the LLM to generate a smarter proxy with those failures as context. The hot-swap is invisible when it works; when it doesn\'t, you find out in the logs instead of in production. The replacement accounts for exactly the mistakes that killed its predecessor.',
  },
  {
    icon: '{~}',
    abjects: 'SkillRegistry',
    title: 'Drop a SKILL.md. The agents already know.',
    hook: 'Claude Code or OpenClaw format. Both work, both at once.',
    desc: 'Skills are markdown files. No build, no install, no registry to register with. The SkillRegistry watches the folder; the next time an abject needs a new ability, it reads what landed. The system grows by adoption, not by programming.',
  },
  {
    icon: '{*}',
    abjects: 'KnowledgeBase',
    title: 'What one abject learns, every abject knows.',
    hook: 'A CRDT knowledge base that crosses machines and survives crashes.',
    desc: 'Save a fact. Save a snippet. Save a reference. Every abject can ask. Every peer syncs. Lose a peer, the memory stays. Add a peer, it gets every fact from the past three weeks.',
  },
];

const capabilities = [
  { icon: '{W}', name: 'Web Browsing', desc: 'Headless Playwright automation' },
  { icon: '{S}', name: 'Web Search', desc: 'Search and fetch with parsing' },
  { icon: '{$}', name: 'Shell Execution', desc: 'Run commands on the host' },
  { icon: '{/}', name: 'Host Filesystem', desc: 'Read and write real files' },
  { icon: '{#}', name: 'Screenshots', desc: 'Capture canvas, widgets, pages' },
  { icon: '{C}', name: 'Scheduled Tasks', desc: 'Cron-like per-workspace jobs' },
  { icon: '{K}', name: 'Knowledge Base', desc: 'Persistent memory, CRDT-synced' },
  { icon: '{.}', name: 'Portable Skills', desc: 'Claude Code & OpenClaw formats' },
  { icon: '{P}', name: 'File Transfer', desc: 'Peer-to-peer, encrypted' },
  { icon: '{M}', name: 'Media Streaming', desc: 'Audio and video capture' },
  { icon: '{&}', name: 'Shared State', desc: 'LWW-CRDT across peers' },
  { icon: '{!}', name: 'Permission Gates', desc: 'Capability-gated trust model' },
];
---

<section id="features">
  <div class="container">
    <h2 class="section-title">What Lurks Inside</h2>
    <p class="features-intro">
      Every one of these is an abject: a living object you can message, kill, restart, fork, or ask what it just did.
    </p>
    <div class="feature-grid">
      {features.map((f) => (
        <div class="card feature-card">
          <div class="card-header">
            <span class="card-icon">{f.icon}</span>
            <span class="card-abjects">{f.abjects}</span>
          </div>
          <h3>{f.title}</h3>
          <p class="hook">{f.hook}</p>
          <p>{f.desc}</p>
        </div>
      ))}
    </div>

    <div id="capabilities" class="cap-block">
      <h3 class="cap-heading">What the Abjects Can Touch</h3>
      <p class="cap-intro">
        Every capability is an abject. Every abject can ask any other what it does.
        The system's reach grows by spawning new abjects, not by adding framework plugins.
      </p>
      <div class="cap-grid">
        {capabilities.map((c) => (
          <div class="cap-pill">
            <span class="cap-icon">{c.icon}</span>
            <div class="cap-text">
              <span class="cap-name">{c.name}</span>
              <span class="cap-desc">{c.desc}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .features-intro {
    text-align: center;
    color: var(--text-secondary);
    font-size: 1rem;
    max-width: 640px;
    margin: -1.5rem auto 2.5rem;
    line-height: 1.7;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  @media (max-width: 900px) {
    .feature-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 520px) {
    .feature-grid {
      grid-template-columns: 1fr;
    }
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .card-icon {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--eldritch);
    background: var(--eldritch-glow);
    border: 1px solid var(--border-accent);
    padding: 0.4rem 0.6rem;
    border-radius: 6px;
  }

  .card-abjects {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--text-dim);
    letter-spacing: 0.01em;
    line-height: 1.4;
  }

  .feature-card .hook {
    color: var(--void-purple);
    font-style: italic;
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
    line-height: 1.5;
  }

  .cap-block {
    margin-top: 4rem;
    scroll-margin-top: 80px;
  }

  .cap-heading {
    text-align: center;
    font-size: 1.5rem;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
  }

  .cap-intro {
    text-align: center;
    color: var(--text-secondary);
    font-size: 1rem;
    max-width: 640px;
    margin: 0 auto 2rem;
    line-height: 1.6;
  }

  .cap-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .cap-pill {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.7rem 0.9rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .cap-pill:hover {
    border-color: var(--border-accent);
    box-shadow: 0 0 12px var(--eldritch-glow);
  }

  .cap-icon {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--eldritch);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .cap-text {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .cap-name {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.3;
  }

  .cap-desc {
    font-size: 0.7rem;
    color: var(--text-dim);
    line-height: 1.3;
  }

  @media (max-width: 768px) {
    .cap-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 520px) {
    .cap-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
