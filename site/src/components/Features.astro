---
const features = [
  {
    icon: '{>}',
    title: 'Spoken Into Being',
    hook: 'Describe what you want. It appears. Alive. Watching.',
    desc: 'Say "a todo list that syncs with my calendar" in plain English. The system writes a manifest, generates code via LLM, and spawns a running object with its own window. From words to living software in seconds.',
  },
  {
    icon: '{@}',
    title: 'No Servers, No Masters',
    hook: 'Your identity is your public key. Your network is your contacts. No cloud required.',
    desc: "Every peer's true name is the SHA-256 hash of its signing key. Connect directly over encrypted WebRTC channels. Peers find each other through stateless signaling relays, then talk peer-to-peer. Networks grow by introduction, not registration.",
  },
  {
    icon: '{=}',
    title: 'Shared Goals, Many Minds',
    hook: 'Post a goal. Abjects explain how they can help. The best approach wins.',
    desc: 'Goals fracture into tasks in a shared TupleSpace synced across peers. Abjects that can help self-assess via the ask protocol. Work distributes across machines. If one peer drops, stale claims expire and others pick up where it left off.',
  },
  {
    icon: '{!}',
    title: 'Scars That Teach',
    hook: 'Every failure is fed back into the wound. The proxy that grows back is smarter.',
    desc: 'When error rates cross 10%, the system collects recent failures and generates a new proxy with the error history as context. The replacement accounts for exactly the mistakes that killed its predecessor.',
  },
  {
    icon: '{~}',
    title: 'Skills From the Wild',
    hook: 'Drop a SKILL.md into the folder. Claude Code or OpenClaw format. Both work.',
    desc: 'Abjects learn new abilities from portable skill files without integration code. The skill registry scans, parses, and injects instructions at runtime. The system grows by adoption, not by programming.',
  },
  {
    icon: '{*}',
    title: 'Memory That Persists',
    hook: 'What one abject learns, all abjects know.',
    desc: 'Facts, insights, and references persist in a searchable knowledge base synced across peers via CRDT. Abjects recall what was learned in previous sessions, on other machines, by other abjects.',
  },
];

const capabilities = [
  { icon: '{W}', name: 'Web Browsing', desc: 'Headless Playwright automation' },
  { icon: '{S}', name: 'Web Search', desc: 'Search and fetch with parsing' },
  { icon: '{$}', name: 'Shell Execution', desc: 'Run commands on the host' },
  { icon: '{/}', name: 'Host Filesystem', desc: 'Read and write real files' },
  { icon: '{#}', name: 'Screenshots', desc: 'Capture canvas, widgets, pages' },
  { icon: '{C}', name: 'Scheduled Tasks', desc: 'Cron-like per-workspace jobs' },
  { icon: '{K}', name: 'Knowledge Base', desc: 'Persistent memory, CRDT-synced' },
  { icon: '{.}', name: 'Portable Skills', desc: 'Claude Code & OpenClaw formats' },
  { icon: '{P}', name: 'File Transfer', desc: 'Peer-to-peer, encrypted' },
  { icon: '{M}', name: 'Media Streaming', desc: 'Audio and video capture' },
  { icon: '{&}', name: 'Shared State', desc: 'LWW-CRDT across peers' },
  { icon: '{!}', name: 'Permission Gates', desc: 'Capability-gated trust model' },
];
---

<section id="features">
  <div class="container">
    <h2 class="section-title">What Lurks Inside</h2>
    <p class="features-intro">
      Every capability below is an Abject itself: a living object with a manifest, a mailbox, and the ability to explain itself to any other object that asks.
    </p>
    <div class="feature-grid">
      {features.map((f) => (
        <div class="card feature-card">
          <span class="card-icon">{f.icon}</span>
          <h3>{f.title}</h3>
          <p class="hook">{f.hook}</p>
          <p>{f.desc}</p>
        </div>
      ))}
    </div>

    <div id="capabilities" class="cap-block">
      <h3 class="cap-heading">What the Abjects Can Touch</h3>
      <p class="cap-intro">
        Every capability is an abject. Every abject can ask any other what it does.
        The system's reach grows by spawning new abjects, not by adding framework plugins.
      </p>
      <div class="cap-grid">
        {capabilities.map((c) => (
          <div class="cap-pill">
            <span class="cap-icon">{c.icon}</span>
            <div class="cap-text">
              <span class="cap-name">{c.name}</span>
              <span class="cap-desc">{c.desc}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .features-intro {
    text-align: center;
    color: var(--text-secondary);
    font-size: 1rem;
    max-width: 640px;
    margin: -1.5rem auto 2.5rem;
    line-height: 1.7;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  @media (max-width: 900px) {
    .feature-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 520px) {
    .feature-grid {
      grid-template-columns: 1fr;
    }
  }

  .card-icon {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--eldritch);
    background: var(--eldritch-glow);
    border: 1px solid var(--border-accent);
    padding: 0.4rem 0.6rem;
    border-radius: 6px;
    margin-bottom: 0.75rem;
  }

  .feature-card .hook {
    color: var(--void-purple);
    font-style: italic;
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
    line-height: 1.5;
  }

  .cap-block {
    margin-top: 4rem;
    scroll-margin-top: 80px;
  }

  .cap-heading {
    text-align: center;
    font-size: 1.5rem;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
  }

  .cap-intro {
    text-align: center;
    color: var(--text-secondary);
    font-size: 1rem;
    max-width: 640px;
    margin: 0 auto 2rem;
    line-height: 1.6;
  }

  .cap-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .cap-pill {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.7rem 0.9rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .cap-pill:hover {
    border-color: var(--border-accent);
    box-shadow: 0 0 12px var(--eldritch-glow);
  }

  .cap-icon {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--eldritch);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .cap-text {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .cap-name {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.3;
  }

  .cap-desc {
    font-size: 0.7rem;
    color: var(--text-dim);
    line-height: 1.3;
  }

  @media (max-width: 768px) {
    .cap-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 520px) {
    .cap-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
