---
const vars = [
  { name: 'ANTHROPIC_API_KEY', default: '—', desc: 'Anthropic Claude API key' },
  { name: 'OPENAI_API_KEY', default: '—', desc: 'OpenAI API key' },
  { name: 'WS_PORT', default: '7719', desc: 'WebSocket port for client connection' },
  { name: 'SIGNALING_PORT', default: '7720', desc: 'Signaling server port for P2P discovery' },
  { name: 'ABJECTS_DATA_DIR', default: '.abjects', desc: 'Persistent storage directory' },
  { name: 'ABJECTS_WORKER_COUNT', default: 'CPU cores - 1', desc: 'Worker thread pool size (max 8)' },
];
---

<section class="config-section">
  <div class="container">
    <h2 class="section-title">Configuration</h2>
    <p class="config-intro">Set environment variables before running <code>pnpm serve</code>. For local LLM, run Ollama on localhost:11434.</p>
    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th>Variable</th>
            <th>Default</th>
            <th>Description</th>
          </tr>
        </thead>
        <tbody>
          {vars.map((v) => (
            <tr>
              <td>{v.name}</td>
              <td class="default-val">{v.default}</td>
              <td>{v.desc}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>

<style>
  .config-section {
    background: linear-gradient(180deg, var(--bg-deep) 0%, var(--bg-surface) 100%);
  }

  .config-intro {
    text-align: center;
    color: var(--text-secondary);
    margin-bottom: 2rem;
  }

  .table-wrapper {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    max-width: 800px;
    margin: 0 auto;
  }

  th {
    background: var(--bg-surface);
  }

  tr:last-child td {
    border-bottom: none;
  }

  .default-val {
    font-family: var(--font-mono);
    color: var(--text-dim);
  }
</style>
