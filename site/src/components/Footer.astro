---
---

<footer>
  <div class="container footer-content">
    <div class="footer-brand">
      <span class="footer-logo">
        <span class="bracket">{</span>abjects<span class="bracket">}</span>
      </span>
      <p>Grass computing from the abyss.</p>
    </div>
    <div class="footer-right">
      <p class="footer-flavor">Made with mass hallucination and message passing</p>
      <div class="footer-links">
        <a href="https://discord.gg/B75AeYUYcF" target="_blank" rel="noopener">Discord</a>
        <span class="sep">|</span>
        <a href="https://github.com/mempko/abject" target="_blank" rel="noopener">GitHub</a>
        <span class="sep">|</span>
        <span class="license">GPL-3.0-or-later</span>
      </div>
    </div>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--border);
    padding: 2.5rem 0;
  }

  .footer-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer-logo {
    font-family: var(--font-mono);
    font-weight: 700;
    color: var(--text-primary);
    font-size: 1rem;
  }

  .bracket {
    color: var(--eldritch);
  }

  .footer-brand p {
    color: var(--text-dim);
    font-size: 0.85rem;
    margin-top: 0.25rem;
  }

  .footer-right {
    text-align: right;
  }

  .footer-flavor {
    color: var(--text-dim);
    font-size: 0.8rem;
    font-style: italic;
    margin-bottom: 0.35rem;
  }

  .footer-links {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.9rem;
  }

  .sep {
    color: var(--border);
  }

  .license {
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }
</style>
