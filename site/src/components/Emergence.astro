        <div class="compare-label">Failure &amp; Recovery</div>
        <div class="compare-systems">LangGraph &middot; CrewAI &middot; AutoGen</div>
        <svg class="compare-svg" viewBox="0 0 900 170" xmlns="http://www.w3.org/2000/svg">
          <!-- Left: chain breaks -->
