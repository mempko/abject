          </defs>

          <!-- TupleSpace central -->
          <rect x="190" y="95" width="240" height="60" rx="10" fill="#12121e" stroke="rgba(57,255,142,0.4)" stroke-width="2" filter="url(#em-glow-green)"/>
          <text x="310" y="122" text-anchor="middle" fill="#39ff8e" font-size="14" font-family="monospace" font-weight="600">TupleSpace</text>
          <!-- Task status icons inside -->
          <text x="245" y="142" fill="rgba(57,255,142,0.5)" font-size="12" font-family="monospace">&#9675; &#9675; &#9679; &#9675;</text>

          <!-- Agent: Chat (top-left) -->
          <rect x="30" y="10" width="120" height="38" rx="6" fill="#12121e" stroke="rgba(57,255,142,0.3)" stroke-width="1.5"/>
          <text x="90" y="34" text-anchor="middle" fill="#39ff8e" font-size="13" font-family="monospace">Chat</text>
          <!-- Bidirectional arrow to TupleSpace -->
          <line x1="115" y1="48" x2="215" y2="95" stroke="#39ff8e" stroke-width="1.5" marker-start="url(#em-arrow-green-rev)" marker-end="url(#em-arrow-green)" filter="url(#em-glow-green)"/>
          <text x="140" y="72" fill="rgba(57,255,142,0.5)" font-size="9" font-family="monospace">watch</text>

          <!-- Agent: WebAgent (top-right) -->
          <rect x="470" y="10" width="120" height="38" rx="6" fill="#12121e" stroke="rgba(57,255,142,0.3)" stroke-width="1.5"/>
          <text x="530" y="34" text-anchor="middle" fill="#39ff8e" font-size="13" font-family="monospace">WebAgent</text>
          <!-- Bidirectional arrow to TupleSpace -->
          <line x1="505" y1="48" x2="405" y2="95" stroke="#39ff8e" stroke-width="1.5" marker-start="url(#em-arrow-green-rev)" marker-end="url(#em-arrow-green)" filter="url(#em-glow-green)"/>
          <text x="478" y="72" fill="rgba(57,255,142,0.5)" font-size="9" font-family="monospace">claim</text>

          <!-- Agent: Creator (bottom) -->
          <rect x="250" y="210" width="120" height="38" rx="6" fill="#12121e" stroke="rgba(57,255,142,0.3)" stroke-width="1.5"/>
          <text x="310" y="234" text-anchor="middle" fill="#39ff8e" font-size="13" font-family="monospace">Creator</text>
          <!-- Bidirectional arrow to TupleSpace -->
          <line x1="310" y1="210" x2="310" y2="155" stroke="#39ff8e" stroke-width="1.5" marker-start="url(#em-arrow-green-rev)" marker-end="url(#em-arrow-green)" filter="url(#em-glow-green)"/>
          <text x="340" y="188" fill="rgba(57,255,142,0.5)" font-size="9" font-family="monospace">complete</text>

          <!-- Decompose recursion loop (dashed) -->
          <path d="M 250,229 C 190,229 160,200 160,155 C 160,120 175,108 190,108" fill="none" stroke="rgba(57,255,142,0.25)" stroke-width="1" stroke-dasharray="4 3"/>
          <text x="135" y="175" fill="rgba(57,255,142,0.35)" font-size="9" font-family="monospace">decompose</text>

          <!-- Caption -->
          <text x="310" y="290" text-anchor="middle" fill="rgba(57,255,142,0.5)" font-size="11" font-family="monospace" font-style="italic">no brain. many minds. the swarm self-organizes.</text>
        </svg>
      </div>
    </div>

    <!-- Zone C: The Lifecycle - Three Steps -->
    <div class="lifecycle">

      <div class="step">
        <div class="step-label">I</div>
        <h3 class="step-title">The Splitting</h3>
        <p class="step-tagline">A goal fractures into the things that must be done.</p>
        <p>An agent receives a goal and thinks. The LLM decomposes it into typed subtasks (browse, create, research) and drops them into the TupleSpace. The goal doesn't know who will do the work. It doesn't need to.</p>
      </div>

      <div class="step-connector">
        <span class="connector-line connector-line-green"></span>
        <span class="connector-glyph connector-glyph-green">&darr;</span>
        <span class="connector-line connector-line-green"></span>
      </div>

      <div class="step">
        <div class="step-label">II</div>
        <h3 class="step-title">The Reaching</h3>
        <p class="step-tagline">Agents sense what they were made for.</p>
        <p>Each agent declares what task types it handles. When a new task appears in the TupleSpace, agents that match its type reach for it first. If no agent declares the type, the system falls back to the LLM: a fast semantic call reads each agent's description and picks the best fit. Nothing is dropped. Optimistic CRDT claims: no locks, no coordinator. Last-write-wins with stale claim recovery. If two agents grab the same task, the conflict resolves itself. The fastest hand wins.</p>
      </div>

      <div class="step-connector">
        <span class="connector-line connector-line-green"></span>
        <span class="connector-glyph connector-glyph-green">&darr;</span>
        <span class="connector-line connector-line-green"></span>
      </div>

      <div class="step">
        <div class="step-label">III</div>
        <h3 class="step-title">The Scar</h3>
        <p class="step-tagline">Failure is not the end. It is a lesson the swarm remembers.</p>
        <p>When an agent fails a task, the failure is recorded: which agent, what went wrong, when. The task releases its claim and returns to the pool. But not blindly. The TupleSpace remembers who failed. The next agent to claim it will be different. After three attempts, the task is marked permanently dead. No infinite loops. No thrashing. The swarm learns from its wounds.</p>
      </div>

    </div>

    <!-- Zone D: Comparison -->
    <div class="comparisons">
      <div class="compare-row">
        <div class="compare-label">Task Coordination</div>
        <div class="compare-systems">AutoGen &middot; CrewAI &middot; LangGraph</div>
        <svg class="compare-svg" viewBox="0 0 900 170" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <marker id="em-cf-arrow-dim" viewBox="0 0 10 10" refX="10" refY="5" markerWidth="6" markerHeight="6" orient="auto">
              <path d="M 0 0 L 10 5 L 0 10 z" fill="#5a5a70"/>
            </marker>
            <marker id="em-cf-arrow-green" viewBox="0 0 10 10" refX="10" refY="5" markerWidth="6" markerHeight="6" orient="auto">
              <path d="M 0 0 L 10 5 L 0 10 z" fill="#39ff8e"/>
            </marker>
            <marker id="em-cf-arrow-green-rev" viewBox="0 0 10 10" refX="0" refY="5" markerWidth="6" markerHeight="6" orient="auto">
              <path d="M 10 0 L 0 5 L 10 10 z" fill="#39ff8e"/>
            </marker>
            <filter id="em-cf-glow">
              <feGaussianBlur stdDeviation="2.5" result="blur"/>
              <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
          </defs>

          <!-- Left: strict dispatch -->
          <text x="195" y="16" text-anchor="middle" fill="#5a5a70" font-size="11" font-family="monospace">rigid dispatch</text>
          <!-- Planner -->
          <rect x="145" y="25" width="100" height="34" rx="6" fill="#12121e" stroke="rgba(255,77,106,0.2)" stroke-width="1"/>
          <text x="195" y="47" text-anchor="middle" fill="#e0e0ea" font-size="13" font-family="monospace">Planner</text>
          <!-- Arrows down to agents -->
          <line x1="170" y1="59" x2="105" y2="85" stroke="#5a5a70" stroke-width="1" marker-end="url(#em-cf-arrow-dim)"/>
          <line x1="195" y1="59" x2="195" y2="85" stroke="#5a5a70" stroke-width="1" marker-end="url(#em-cf-arrow-dim)"/>
          <line x1="220" y1="59" x2="285" y2="85" stroke="#5a5a70" stroke-width="1" marker-end="url(#em-cf-arrow-dim)"/>
          <!-- Agents -->
          <rect x="55" y="88" width="90" height="28" rx="5" fill="#12121e" stroke="#1a1a2a" stroke-width="1"/>
          <text x="100" y="107" text-anchor="middle" fill="#5a5a70" font-size="11" font-family="monospace">Agent</text>
          <rect x="150" y="88" width="90" height="28" rx="5" fill="#12121e" stroke="#1a1a2a" stroke-width="1"/>
          <text x="195" y="107" text-anchor="middle" fill="#5a5a70" font-size="11" font-family="monospace">Agent</text>
          <rect x="245" y="88" width="90" height="28" rx="5" fill="#12121e" stroke="#1a1a2a" stroke-width="1"/>
          <text x="290" y="107" text-anchor="middle" fill="#5a5a70" font-size="11" font-family="monospace">Agent</text>
          <!-- Arrows down to tools -->
          <line x1="100" y1="116" x2="100" y2="136" stroke="#5a5a70" stroke-width="1" marker-end="url(#em-cf-arrow-dim)"/>
          <line x1="195" y1="116" x2="195" y2="136" stroke="#5a5a70" stroke-width="1" marker-end="url(#em-cf-arrow-dim)"/>
          <line x1="290" y1="116" x2="290" y2="136" stroke="#5a5a70" stroke-width="1" marker-end="url(#em-cf-arrow-dim)"/>
          <rect x="72" y="138" width="56" height="22" rx="4" fill="#12121e" stroke="#1a1a2a" stroke-width="1"/>
          <text x="100" y="153" text-anchor="middle" fill="#5a5a70" font-size="9" font-family="monospace">Tool</text>
          <rect x="167" y="138" width="56" height="22" rx="4" fill="#12121e" stroke="#1a1a2a" stroke-width="1"/>
          <text x="195" y="153" text-anchor="middle" fill="#5a5a70" font-size="9" font-family="monospace">Tool</text>
          <rect x="262" y="138" width="56" height="22" rx="4" fill="#12121e" stroke="#1a1a2a" stroke-width="1"/>
          <text x="290" y="153" text-anchor="middle" fill="#5a5a70" font-size="9" font-family="monospace">Tool</text>
          <!-- Caption -->
          <text x="195" y="12" text-anchor="middle" fill="#5a5a70" font-size="9" font-family="monospace" opacity="0.0"></text>

          <!-- Divider -->
          <line x1="420" y1="10" x2="420" y2="160" stroke="#1a1a2a" stroke-width="1" stroke-dasharray="4 4"/>

          <!-- Right: autonomous swarm -->
          <text x="660" y="16" text-anchor="middle" fill="rgba(57,255,142,0.5)" font-size="11" font-family="monospace">autonomous swarm</text>
          <!-- TupleSpace center -->
          <rect x="610" y="55" width="100" height="50" rx="8" fill="#12121e" stroke="rgba(57,255,142,0.4)" stroke-width="1.5" filter="url(#em-cf-glow)"/>
          <text x="660" y="77" text-anchor="middle" fill="#39ff8e" font-size="11" font-family="monospace">TupleSpace</text>
          <text x="660" y="95" text-anchor="middle" fill="rgba(57,255,142,0.4)" font-size="10" font-family="monospace">&#9675; &#9679; &#9675;</text>
          <!-- Agents watching from edges -->
          <rect x="490" y="35" width="80" height="28" rx="5" fill="#12121e" stroke="rgba(57,255,142,0.3)" stroke-width="1"/>
          <text x="530" y="54" text-anchor="middle" fill="#39ff8e" font-size="10" font-family="monospace">Chat</text>
          <rect x="750" y="35" width="80" height="28" rx="5" fill="#12121e" stroke="rgba(57,255,142,0.3)" stroke-width="1"/>
          <text x="790" y="54" text-anchor="middle" fill="#39ff8e" font-size="10" font-family="monospace">WebAgent</text>
          <rect x="620" y="125" width="80" height="28" rx="5" fill="#12121e" stroke="rgba(57,255,142,0.3)" stroke-width="1"/>
          <text x="660" y="144" text-anchor="middle" fill="#39ff8e" font-size="10" font-family="monospace">Creator</text>
          <!-- Bidirectional arrows -->
          <line x1="570" y1="55" x2="610" y2="65" stroke="#39ff8e" stroke-width="1" marker-start="url(#em-cf-arrow-green-rev)" marker-end="url(#em-cf-arrow-green)" filter="url(#em-cf-glow)"/>
          <line x1="750" y1="55" x2="710" y2="65" stroke="#39ff8e" stroke-width="1" marker-start="url(#em-cf-arrow-green-rev)" marker-end="url(#em-cf-arrow-green)" filter="url(#em-cf-glow)"/>
          <line x1="660" y1="125" x2="660" y2="105" stroke="#39ff8e" stroke-width="1" marker-start="url(#em-cf-arrow-green-rev)" marker-end="url(#em-cf-arrow-green)" filter="url(#em-cf-glow)"/>
          <!-- Caption -->
          <text x="660" y="168" text-anchor="middle" fill="rgba(57,255,142,0.5)" font-size="10" font-family="monospace" font-style="italic">no one sees all. everyone acts.</text>
        </svg>
        <div class="compare-pair">
          <div class="compare-side compare-them">
            <span class="compare-tag">Them</span>
            <p>AutoGen assigns roles in conversation. CrewAI defines crews with fixed task pipelines. LangGraph routes through a state machine the developer designs. In all of them, something at the top decides who does what. Kill the planner, kill the system. A single point of comprehension, a single point of failure.</p>
          </div>
          <div class="compare-side compare-abjects">
            <span class="compare-tag compare-tag-abjects">Abjects</span>
            <p>No planner. No role assignment. No state machine. The TupleSpace holds tasks. Agents watch autonomously and claim what they know how to do. When no agent declares the type, an LLM semantic fallback picks the best fit by description — no task is ever silently dropped. Failure records which agent failed, and a different one picks up the dropped work. The swarm has no brain to kill. It coordinates through shared memory, meaning, and scars.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Zone E: Closing -->
    <div class="emergence-closing">
      <p class="closing-line">Three primitives. That's all it takes. A shared space for tasks. Optimistic claims that resolve themselves. Failure memory that prevents the same mistake twice.</p>
      <p class="closing-line closing-vivid">From these, complex coordination emerges: goals that decompose into subtasks, agents that self-select, retry chains that route around damage. No orchestrator designed this behavior. No planner anticipated it. It simply <em>arises</em>, the way flocking arises from three rules about distance, alignment, and separation. The way an immune system arises from cells that recognize what is foreign and destroy it without being told.</p>
      <p class="closing-definition"><em>emergence</em> (n.) - complex behavior that arises from simple local interactions. No conductor. No score. The music plays itself.</p>
    </div>

  </div>
</section>

<style>
  .emergence-section {
    background: linear-gradient(180deg, var(--bg-deep) 0%, #0a0d12 50%, var(--bg-deep) 100%);
  }

  .emergence-subtitle {
    text-align: center;
    color: var(--void-purple);
    font-size: 1.1rem;
    margin-top: -2rem;
    margin-bottom: 1.5rem;
  }

  .emergence-thesis {
    max-width: 700px;
    margin: 0 auto 3rem;
    text-align: center;
    color: var(--text-secondary);
    font-size: 1rem;
    line-height: 1.8;
  }

  /* Diagrams */
  .diagrams {
    max-width: 640px;
    margin: 0 auto 3.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .diagram-label {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.5rem;
    color: var(--text-dim);
  }

  .diagram-label-new {
    color: var(--eldritch);
  }

  .diagram-svg {
    width: 100%;
    display: block;
  }

  .diagram-svg-old {
    opacity: 0.7;
  }

  .diagram-svg-new {
    filter: drop-shadow(0 0 24px rgba(57, 255, 142, 0.08));
  }

  /* Lifecycle Steps */
  .lifecycle {
    max-width: 640px;
    margin: 0 auto 3.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .step {
    width: 100%;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.75rem 2rem;
    position: relative;
    transition: border-color 0.3s, box-shadow 0.3s;
  }

  .step:hover {
    border-color: rgba(57, 255, 142, 0.3);
    box-shadow: 0 0 24px var(--eldritch-glow);
  }

  .step-label {
    position: absolute;
    top: -0.6rem;
    right: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    background: #0a0d12;
    padding: 0 0.5rem;
    color: var(--eldritch);
  }

  .step-title {
    color: var(--eldritch);
    margin-bottom: 0.25rem;
  }

  .step-tagline {
    font-style: italic;
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
    color: var(--void-purple);
  }

  .step p:last-child {
    color: var(--text-secondary);
    font-size: 0.95rem;
  }

  /* Step Connectors */
  .step-connector {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    padding: 0.25rem 0;
  }

  .connector-line {
    width: 1px;
    height: 12px;
  }

  .connector-line-green {
    background: rgba(57, 255, 142, 0.3);
    box-shadow: 0 0 6px var(--eldritch-glow);
  }

  .connector-glyph {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    line-height: 1;
  }

  .connector-glyph-green {
    color: var(--eldritch);
  }

  /* Comparisons */
  .comparisons {
    max-width: 900px;
    margin: 0 auto 3.5rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .compare-row {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .compare-label {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--text-primary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .compare-systems {
    color: var(--void-purple);
    font-size: 0.8rem;
    font-style: italic;
  }

  .compare-svg {
    width: 100%;
    display: block;
    margin-bottom: 0.75rem;
  }

  .compare-pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .compare-side {
    border-radius: 10px;
    padding: 1.25rem 1.5rem;
    font-size: 0.9rem;
    line-height: 1.7;
  }

  .compare-side p {
    color: var(--text-secondary);
  }

  .compare-them {
    background: var(--bg-card);
    border: 1px solid var(--border);
  }

  .compare-abjects {
