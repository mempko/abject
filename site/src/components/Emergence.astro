          <rect x="700" y="28" width="150" height="90" rx="8" fill="#12121e" stroke="rgba(57,255,142,0.3)" stroke-width="1.5"/>
          <text x="775" y="46" text-anchor="middle" fill="rgba(57,255,142,0.5)" font-size="10" font-family="monospace">Peer B</text>
