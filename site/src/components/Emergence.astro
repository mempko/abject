          <!-- Wall on right edge -->
          <line x1="320" y1="28" x2="320" y2="128" stroke="rgba(255,77,106,0.3)" stroke-width="2"/>
          <text x="335" y="82" fill="rgba(255,77,106,0.3)" font-size="16" font-family="monospace">&#10005;</text>
          <text x="195" y="150" text-anchor="middle" fill="#5a5a70" font-size="10" font-family="monospace" font-style="italic" opacity="0.6">agents trapped in one process</text>

          <!-- Divider -->
          <line x1="420" y1="10" x2="420" y2="160" stroke="#1a1a2a" stroke-width="1" stroke-dasharray="4 4"/>

          <!-- Right: peer mesh -->
          <text x="660" y="16" text-anchor="middle" fill="rgba(57,255,142,0.5)" font-size="11" font-family="monospace">peer mesh</text>
          <!-- Peer A -->
          <rect x="470" y="28" width="150" height="90" rx="8" fill="#12121e" stroke="rgba(57,255,142,0.3)" stroke-width="1.5"/>
          <text x="545" y="46" text-anchor="middle" fill="rgba(57,255,142,0.5)" font-size="10" font-family="monospace">Peer A</text>
          <rect x="485" y="54" width="120" height="26" rx="5" fill="#12121e" stroke="rgba(57,255,142,0.2)" stroke-width="1"/>
          <text x="545" y="72" text-anchor="middle" fill="rgba(57,255,142,0.4)" font-size="9" font-family="monospace">TupleSpace</text>
          <rect x="495" y="88" width="45" height="20" rx="4" fill="#12121e" stroke="rgba(57,255,142,0.2)" stroke-width="1"/>
          <text x="517" y="102" text-anchor="middle" fill="#39ff8e" font-size="8" font-family="monospace">Chat</text>
