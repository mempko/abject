---
const capabilities = [
  { name: 'HttpClient', desc: 'HTTP requests with domain allow/deny rules' },
  { name: 'Storage', desc: 'Persistent key-value store (IndexedDB-backed)' },
  { name: 'Timer', desc: 'Scheduling, delays, and intervals' },
  { name: 'Clipboard', desc: 'System clipboard access' },
  { name: 'Console', desc: 'Debug logging and output' },
  { name: 'FileSystem', desc: 'Virtual filesystem operations' },
  { name: 'WebBrowser', desc: 'Headless browser automation (Playwright, server-only)' },
  { name: 'WebParser', desc: 'HTML parsing and content extraction (linkedom, server-only)' },
];
---

<section class="cap-section">
  <div class="container">
    <h2 class="section-title">Capability Objects</h2>
    <p class="cap-intro">Built-in objects that provide system capabilities to sandboxed WASM objects:</p>
    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th>Object</th>
            <th>Description</th>
          </tr>
        </thead>
        <tbody>
          {capabilities.map((c) => (
            <tr>
              <td>{c.name}</td>
              <td>{c.desc}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>

<style>
  .cap-intro {
    text-align: center;
    color: var(--text-secondary);
    margin-bottom: 2rem;
    font-size: 1rem;
  }

  .table-wrapper {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    max-width: 700px;
    margin: 0 auto;
  }

  table {
    margin: 0;
  }

  th {
    background: var(--bg-surface);
  }

  tr:last-child td {
    border-bottom: none;
  }
</style>
