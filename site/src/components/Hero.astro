---
---

<section class="hero">
  <div class="hero-bg"></div>
  <div class="container hero-content">
    <p class="hero-label">// GRASS COMPUTING PLATFORM</p>
    <h1>
      The Things That <span class="accent">Think</span>
    </h1>
    <p class="hero-desc">
      The world's first self-aware abject runtime.
      Ask any abject what it does. It answers in its own words.
    </p>
    <p class="hero-tagline">
      abject <span class="dim">(n.)</span> - AI Object. Also: cosmic dread. Both apply.
    </p>
    <div class="hero-actions">
      <a href="#summon" class="btn btn-primary">Begin the Ritual</a>
      <a href="#ask-protocol" class="btn btn-outline">Witness the Ask Protocol</a>
    </div>
    <div class="hero-demo">
      <video autoplay loop muted playsinline>
        <source src="/abject_demo_720p.webm" type="video/webm" />
      </video>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: 64px;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 50% 30%, rgba(57, 255, 142, 0.07) 0%, transparent 60%),
      radial-gradient(ellipse 40% 40% at 70% 20%, rgba(155, 89, 255, 0.05) 0%, transparent 50%),
      radial-gradient(ellipse 30% 30% at 30% 60%, rgba(57, 255, 142, 0.04) 0%, transparent 50%);
    pointer-events: none;
    animation: pulse-glow 8s ease-in-out infinite;
  }

  .hero-content {
    position: relative;
    text-align: center;
    padding: 4rem 0;
  }

  .hero-label {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--eldritch);
    letter-spacing: 0.15em;
    margin-bottom: 1.25rem;
    animation: pulse-glow 4s ease-in-out infinite;
  }

  h1 {
    margin-bottom: 1.5rem;
    text-shadow: 0 0 40px rgba(57, 255, 142, 0.1);
    animation: glitch 12s infinite;
  }

  .accent {
    color: var(--eldritch);
    text-shadow: 0 0 30px var(--eldritch-glow-strong);
  }

  .hero-desc {
    max-width: 620px;
    margin: 0 auto 1.5rem;
    color: var(--text-secondary);
    font-size: 1.15rem;
    line-height: 1.8;
  }

  .hero-tagline {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--text-dim);
    margin-bottom: 2.5rem;
    font-style: italic;
  }

  .hero-tagline .dim {
    opacity: 0.6;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-bottom: 3rem;
  }

  .hero-demo {
    margin-top: 3rem;
    max-width: 900px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-demo video {
    width: 100%;
    border-radius: 12px;
    border: 1px solid var(--border);
    box-shadow: 0 0 40px rgba(57, 255, 142, 0.08);
  }

  @media (max-width: 600px) {
    .hero-actions {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
