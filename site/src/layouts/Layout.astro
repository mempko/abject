---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Abjects that heal themselves, negotiate with alien minds, and refuse to die. A grass computing platform.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#030308" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <canvas id="abyss-bg"></canvas>
    <slot />
    <script src="../scripts/abyss-bg.js"></script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
